    {
      "id": 17,
      "type": "timeseries",
      "title": "Static cache: hits, misses, writes",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "refId": "Q14",
          "expr": "sum(rate(statamic_static_cache_operations_total{service_name=~\"$service\",operation=\"hit\"}[$__rate_interval])) * 60",
          "legendFormat": "hit",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "Q15",
          "expr": "sum(rate(statamic_static_cache_operations_total{service_name=~\"$service\",operation=\"miss\"}[$__rate_interval])) * 60",
          "legendFormat": "miss",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "refId": "Q16",
          "expr": "sum(rate(statamic_static_cache_operations_total{service_name=~\"$service\",operation=\"write\"}[$__rate_interval])) * 60",
          "legendFormat": "write",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true,
            "axisSoftMin": 0,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "hit"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "miss"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "write"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "invalidate"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
