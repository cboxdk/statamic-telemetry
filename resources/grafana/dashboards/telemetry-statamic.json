    {
      "id": 23,
      "type": "timeseries",
      "title": "Stache cache traffic by key group",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "refId": "Q22",
          "expr": "sum by (key_group) (rate(cache_operations_total{service_name=~\"$service\",key_group=~\"stache.*\"}[$__rate_interval])) * 60",
          "legendFormat": "{{key_group}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
